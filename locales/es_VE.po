msgid ""
"Transfer authorized without assignment of technician or associated group"
msgstr "Traspaso autorizado sin asignación de técnico o grupo asociado"

#: src/Ticket.php:144 src/Ticket.php:507
msgid "You must be assigned to the ticket to be able to transfer it"
msgstr "Debes estar asignado al caso para poder transferirlo"

#: src/Ticket.php:156
msgid ""
"You don't have right to update tickets. Please contact your administrator."
msgstr ""
"No tienes derecho a actualizar casos. Por favor contacte a su administrador."

#: src/Ticket.php:166
msgid "No entity available found, transfer impossible."
msgstr "No se encontró ninguna entidad disponible, transferencia imposible."

#: src/Ticket.php:177
msgid "Unauthorized transfer on closed ticket."
msgstr "Traslado no autorizado en caso cerrado."

#: src/Ticket.php:473
msgid "Please explain your transfer"
msgstr "Por favor explica tu transferencia"

#: src/Ticket.php:490 src/Ticket.php:531
